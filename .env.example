# ==============================================
# Auto-Research-DS 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ==============================================

# --- 数据库 ---
POSTGRES_USER=auto_research
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_DB=auto_research_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LLM ---
LLM_PROVIDER=deepseek
LLM_RUNTIME_CONFIG_PATH=./uploads/llm-runtime-config.json

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# --- OpenAI Chat Completions 兼容 API（可选） ---
# 配置后可在设置页 API 栏切换到 GPT-5.5 兼容模型。
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_API_BASE=
OPENAI_COMPATIBLE_MODEL=gpt-5.5

# --- Token 费用估算（CNY / 1M tokens） ---
# 请按你的实际服务商价格修改；OpenAI-compatible 默认 0 表示未配置价格。
USAGE_DEEPSEEK_INPUT_CNY_PER_1M=3
USAGE_DEEPSEEK_OUTPUT_CNY_PER_1M=6
USAGE_OPENAI_COMPATIBLE_INPUT_CNY_PER_1M=0
USAGE_OPENAI_COMPATIBLE_OUTPUT_CNY_PER_1M=0
USAGE_FALLBACK_INPUT_CNY_PER_1M=3
USAGE_FALLBACK_OUTPUT_CNY_PER_1M=6

# --- 联网搜索（可选；未配置时回退 Bing + DuckDuckGo HTML） ---
SEARXNG_API_URL=
TAVILY_API_KEY=
EXA_API_KEY=
BRAVE_SEARCH_API_KEY=

# --- 应用配置 ---
APP_NAME=Auto-Research-DS
APP_ENV=development
DEBUG=true
SECRET_KEY=change_me_to_random_secret_key_64chars
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# --- 文件存储 ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- arXiv API ---
ARXIV_API_BASE=https://arxiv.org/api/query
ARXIV_API_FALLBACK_BASE=https://export.arxiv.org/api/query
ARXIV_SEARCH_TIMEOUT_SECONDS=6
ARXIV_REQUEST_DELAY_SECONDS=3
ARXIV_CACHE_TTL_SECONDS=300
# PDF 阅读与全文解析：可按部署环境填写已验证的国内镜像，多个地址用逗号分隔。
# 示例格式：https://your-mirror.example/arxiv/pdf,https://another-mirror.example/pdf
ARXIV_PDF_MIRROR_BASE_URLS=
ARXIV_PDF_OFFICIAL_BASE_URL=https://arxiv.org/pdf
ARXIV_PDF_CACHE_DIR=./uploads/arxiv-pdfs
ARXIV_PDF_TIMEOUT_SECONDS=30

# --- 学术检索元数据（可选） ---
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_MAILTO=
# Google Scholar 不提供直接公共 API；配置后通过 SerpApi Google Scholar engine 接入
SERPAPI_API_KEY=

# --- 本地向量模型 / HuggingFace 镜像 ---
# 论文库“补向量”会首次下载 sentence-transformers 模型。服务器无法直连 huggingface.co 时，
# 可设置 HF_ENDPOINT=https://hf-mirror.com；模型缓存会挂载到 Docker volume，重启后复用。
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
HF_ENDPOINT=
HF_HOME=/app/model-cache/huggingface
TRANSFORMERS_CACHE=/app/model-cache/transformers
SENTENCE_TRANSFORMERS_HOME=/app/model-cache/sentence-transformers

# --- PDF 结构化解析 ---
# auto 会优先使用已安装的 Docling 或命令解析器，失败时回退到轻量 pdfplumber 解析。
PDF_STRUCTURED_PARSER_BACKEND=auto
PDF_STRUCTURED_PARSER_COMMAND=
PDF_STRUCTURED_PARSER_TIMEOUT_SECONDS=120
PDF_STRUCTURED_PARSER_MAX_OUTPUT_BYTES=5000000
PDF_VISUAL_EVIDENCE_MAX_MODEL_CALLS=0
PDF_TABLE_PARSER_COMMAND=
PDF_TABLE_PARSER_TIMEOUT_SECONDS=180
PDF_TABLE_PARSER_MAX_OUTPUT_BYTES=10000000
PDF_VISUAL_ASSET_ENABLED=true
PDF_VISUAL_ASSET_MAX_PAGES=12
PDF_VISUAL_ASSET_MAX_ASSETS=40
PDF_VISUAL_ASSET_RENDER_SCALE=1.25
PDF_VISUAL_ASSET_IMAGE_FORMAT=png
# 第一阶段默认不自动调用视觉模型；打开后会尝试用当前支持 image input 的 LLM 生成图表摘要。
PDF_VISUAL_SUMMARY_ENABLED=false
PDF_VISUAL_SUMMARY_MAX_ASSETS=8

# --- 日志 ---
LOG_LEVEL=INFO
